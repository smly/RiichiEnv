{
  "name": "riichienv-ui",
  "version": "0.4.0",
  "description": "Replay viewer and live game visualizer for RiichiEnv",
  "main": "dist/viewer.js",
  "module": "dist/viewer.esm.js",
  "exports": {
    ".": {
      "import": "./dist/viewer.esm.js"
    }
  },
  "scripts": {
    "build:wasm": "bash scripts/build-wasm.sh",
    "build:tiles": "node scripts/gen_tiles.js",
    "build:bundle": "esbuild src/index.ts --bundle --minify --outfile=dist/viewer.js --format=iife --loader:.wasm=binary",
    "build:esm": "esbuild src/index.ts --bundle --minify --outfile=dist/viewer.esm.js --format=esm --loader:.wasm=binary",
    "build:compress": "node scripts/compress.js",
    "build:copy": "cp dist/viewer.js.gz ../src/riichienv/visualizer/assets/viewer.js.gz",
    "build": "npm run build:wasm && npm run build:tiles && npm run build:bundle && npm run build:esm && npm run build:compress && npm run build:copy",
    "build:no-wasm": "npm run build:tiles && npm run build:bundle && npm run build:esm && npm run build:compress && npm run build:copy",
    "watch": "esbuild src/index.ts --bundle --outfile=dist/viewer.js --format=iife --loader:.wasm=binary --global-name=RiichiEnvViewer --watch",
    "dev": "esbuild src/index.ts --bundle --outfile=dist/viewer.js --format=iife --loader:.wasm=binary --servedir=.",
    "lint": "biome check src/",
    "lint:fix": "biome check src/ --fix",
    "format": "biome format src/ --write",
    "format:check": "biome format src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "esbuild": "^0.27.3",
    "sharp": "^0.34.5",
    "svgo": "^4.0.1",
    "text-to-svg": "^3.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "author": "",
  "license": "Apache-2.0"
}
